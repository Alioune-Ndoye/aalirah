Options -Indexes
RewriteEngine On

# ── Service pages ──────────────────────────────────────────────
# Maps /residential-cleaning/, /commercial-cleaning/, etc. → service.php?slug={slug}
RewriteRule ^(residential-cleaning|commercial-cleaning|move-out-cleaning|airbnb-cleaning|post-construction-cleaning|luxury-estate-cleaning|deep-cleaning|event-prep-cleaning|recurring-cleaning)/?$ service.php?slug=$1 [L,QSA]

# ── City landing pages ─────────────────────────────────────────
# Maps /cleaning-services-{city-slug}/ → location.php?slug={city-slug}
RewriteRule ^cleaning-services-([a-z0-9-]+)/?$ location.php?slug=$1 [L,QSA]

# ── Clean trailing-slash redirect for root pages ───────────────
# Redirects /index.php → / (canonical home)
RewriteCond %{THE_REQUEST} ^GET.*index\.php [NC]
RewriteRule ^index\.php$ / [R=301,L]

# ── Default directory index ────────────────────────────────────
DirectoryIndex index.php

# ── Security headers ───────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Cache static assets ────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css                  "access plus 1 month"
  ExpiresByType application/javascript    "access plus 1 month"
  ExpiresByType image/png                 "access plus 3 months"
  ExpiresByType image/jpg                 "access plus 3 months"
  ExpiresByType image/jpeg                "access plus 3 months"
  ExpiresByType image/webp                "access plus 3 months"
  ExpiresByType image/svg+xml             "access plus 3 months"
  ExpiresByType application/json          "access plus 1 week"
</IfModule>

# ── Gzip compression ───────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/xml
</IfModule>
