# Aalirah React app — environment template. Copy to `.env` (or `.env.local`).
#
# Base URL of the review API server (the Node/Express + MongoDB backend in /server).
# Leave EMPTY to run the local-storage demo (no backend needed).
# Set it to enable real, secured review storage:
VITE_API_URL=
# e.g. VITE_API_URL=http://localhost:4000   (dev)
#      VITE_API_URL=https://api.yourdomain.com   (production)
